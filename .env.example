# Copy to .env and adjust. Used by both the postgres service and the server service's
# connection string (see docker-compose.yml).
POSTGRES_USER=chaos
POSTGRES_PASSWORD=change-me
POSTGRES_DB=chaos_coordinator

# Microsoft Graph — sends real verification/invite/welcome email via the Azure App Registration's
# client-credentials flow (Mail.Send application permission on EMAIL_FROM's mailbox). Leave any of
# these blank and the server logs the email link instead of sending it — registration and invite
# flows still work end-to-end, they just don't deliver anything.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
EMAIL_FROM=

# Base URL used to build links inside those emails (verify-email/accept-invite), e.g.
# https://chaos.example.com. Defaults to http://localhost:5173 if unset.
APP_URL=
