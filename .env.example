# Copy to .env and adjust. Used by both the postgres service and the server service's
# connection string (see docker-compose.yml).
POSTGRES_USER=chaos
POSTGRES_PASSWORD=change-me
POSTGRES_DB=chaos_coordinator

# Microsoft Graph — sends real verification/invite/welcome email via the Azure App Registration's
# client-credentials flow (Mail.Send application permission on EMAIL_FROM's mailbox). Leave any of
# these blank and the server logs the email link instead of sending it — registration and invite
# flows still work end-to-end, they just don't deliver anything.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
EMAIL_FROM=

# Base URL used to build links inside those emails (verify-email/accept-invite), e.g.
# https://chaos.example.com. Defaults to http://localhost:5173 if unset.
APP_URL=

# Cloudflare Turnstile (bot protection on login/registration). SITE_KEY is baked into the
# frontend at build time (docker-compose.yml/.dev.yml pass it through as a build arg — that's why
# it needs to be in this file, not just the server's runtime env_file), SECRET_KEY is verified
# server-side. Leave both blank and Turnstile is skipped entirely (no-op verifier).
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Web Push (calendar reminders, chore alarms, chore-completion alerts). Generate a pair with the
# WebPush package's VapidHelper.GenerateVapidKeys() or `npx web-push generate-vapid-keys`.
# SUBJECT is a mailto: address the push services can contact if they need to reach you about your
# usage. Leave all three blank and pushes are logged instead of sent (no-op sender) — reminders/
# alarms are computed on schedule either way, they just don't deliver.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# Local Ollama vision model for the "create events from a photo" import flow. Ollama itself runs
# on the host, not in Docker — BASE_URL defaults to http://localhost:11434 for bare-metal/dev use;
# set it to http://host.docker.internal:11434 when running the server via docker-compose.dev.yml
# (that container already has host.docker.internal wired to the host gateway). Unlike the
# integrations above, there's no no-op fallback — if this can't be reached, that flow returns a
# clear error instead of silently degrading.
# VISION_MODEL defaults to "llava" (7B, ~4.8GB VRAM) — meaningfully better than "moondream"
# (~1.7GB) at reading real photos (correct dates, cleaner times, real notes). Requires Ollama
# 0.32.1+: older versions force the whole model onto the GPU and reliably crash the runner the
# moment an image is attached on a 6GB-VRAM card; 0.32.1+ auto-splits CPU/GPU and this is fixed
# (confirmed on this host). On an older Ollama, fall back to OLLAMA_VISION_MODEL=moondream.
OLLAMA_BASE_URL=
OLLAMA_VISION_MODEL=

# Set to "true" to log the full prompt sent to Ollama and the raw response received back (at
# Information level, so it shows up in the console with no other logging config needed). Off by
# default — the prompt includes any pasted text verbatim and the response can be verbose. Toggle
# any time; only needs a container restart, not a rebuild.
OLLAMA_LOG_PROMPTS=

# Claude API alternative for the same "create events from a photo" flow — takes priority over
# Ollama above when set (no local VRAM/hardware constraints, at a small per-request cost; see
# ClaudeEventExtractionService). Get a key at https://console.anthropic.com/settings/keys.
# VISION_MODEL defaults to "claude-haiku-4-5" — cheap and fast for a single-image extraction call.
ANTHROPIC_API_KEY=
ANTHROPIC_VISION_MODEL=
ANTHROPIC_LOG_PROMPTS=
